generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// חשבון בנק או כרטיס אשראי
model Account {
  id          String      @id @default(uuid())
  name        String      // שם החשבון (לדוגמה: "ישראכרט - 1234")
  institution Institution
  cardNumber  String?     // 4 ספרות אחרונות של הכרטיס (אופציונלי)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  transactions Transaction[]
  fileUploads  FileUpload[]

  @@unique([institution, cardNumber]) // מונע כפילות של אותו כרטיס
  @@index([institution])
}

enum Institution {
  BANK_HAPOALIM
  BANK_LEUMI
  ISRACARD
  LEUMI_CARD
  OTHER
}

// קובץ שהועלה
model FileUpload {
  id           String       @id @default(uuid())
  accountId    String
  account      Account      @relation(fields: [accountId], references: [id])
  filename     String
  originalName String
  rowCount     Int
  status       UploadStatus @default(COMPLETED)
  source       UploadSource @default(WEB)
  processedAt  DateTime     @default(now())

  transactions Transaction[]

  @@index([accountId, processedAt])
  @@index([source, processedAt])
}

enum UploadStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum UploadSource {
  WEB
  TELEGRAM
}

// תנועה בודדת
model Transaction {
  id           String   @id @default(uuid())
  accountId    String
  account      Account  @relation(fields: [accountId], references: [id])
  fileUploadId String?
  fileUpload   FileUpload? @relation(fields: [fileUploadId], references: [id])

  // נתוני התנועה
  date         DateTime
  valueDate    DateTime?
  amount       Decimal  @db.Decimal(12, 2)
  description  String
  merchantName String?

  // קטגוריזציה
  categoryId        String?
  category          Category? @relation(fields: [categoryId], references: [id])
  isAutoCategorized Boolean   @default(false)

  // מטא-דאטה
  reference   String?
  notes       String?
  isExcluded  Boolean @default(false)
  isRecurring Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([accountId, date, amount, description])
  @@index([accountId, date])
  @@index([categoryId])
  @@index([date])
}

// קבלה בודדת מחנות/סופר
model Receipt {
  id                  String        @id @default(uuid())
  storeId             String?
  store               Store?        @relation(fields: [storeId], references: [id], onDelete: SetNull)
  capturedAt          DateTime      @default(now())
  purchaseAt          DateTime?
  totalAmount         Decimal?      @db.Decimal(12, 2)
  currency            String        @default("ILS")
  status              ReceiptStatus @default(PENDING_UPLOAD)
  imageStorageKey     String?
  thumbnailStorageKey String?
  rawOcrText          String?
  parserVersion       String?
  parseError          String?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  items ReceiptItem[]

  @@index([status, capturedAt])
  @@index([purchaseAt])
  @@index([storeId, purchaseAt])
}

// שורה בודדת מתוך קבלה
model ReceiptItem {
  id              String                  @id @default(uuid())
  receiptId       String
  receipt         Receipt                 @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  productId       String?
  product         Product?                @relation(fields: [productId], references: [id], onDelete: SetNull)
  rawName         String
  normalizedName  String?
  brand           String?
  quantity        Decimal?                @db.Decimal(12, 3)
  unit            String?
  unitPrice       Decimal?                @db.Decimal(12, 2)
  linePrice       Decimal?                @db.Decimal(12, 2)
  discountAmount  Decimal?                @db.Decimal(12, 2)
  confidenceScore Float?
  reviewStatus    ReceiptItemReviewStatus @default(UNREVIEWED)
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  priceObservations PriceObservation[]

  @@index([receiptId])
  @@index([productId])
}

// קטגוריה
model Category {
  id        String       @id @default(uuid())
  name      String       @unique // שם בעברית
  nameEn    String?      // שם באנגלית
  icon      String?      // אייקון (emoji או icon name)
  color     String?      // צבע HEX
  type      CategoryType
  sortOrder Int          @default(0)

  transactions Transaction[]
  keywords     CategoryKeyword[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CategoryType {
  EXPENSE
  INCOME
  TRANSFER
}

// מילות מפתח לקטגוריזציה אוטומטית
model CategoryKeyword {
  id         String   @id @default(uuid())
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  keyword    String
  isExact    Boolean  @default(false)
  priority   Int      @default(0)

  @@unique([categoryId, keyword])
  @@index([keyword])
}

// מילות מפתח לזיהוי הוצאות קבועות
model RecurringKeyword {
  id        String   @id @default(uuid())
  keyword   String   @unique
  createdAt DateTime @default(now())

  @@index([keyword])
}

// חנות/סניף שמופיעים בקבלות
model Store {
  id            String   @id @default(uuid())
  name          String
  chain         String?
  branchName    String?
  branchAddress String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  receipts          Receipt[]
  priceObservations PriceObservation[]

  @@index([name])
  @@index([chain, name])
}

// מוצר קנוני להיסטוריית מחירים וקניות
model Product {
  id            String   @id @default(uuid())
  canonicalName String
  brand         String?
  categoryName  String?
  barcode       String?  @unique
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  aliases           ProductAlias[]
  receiptItems      ReceiptItem[]
  priceObservations PriceObservation[]

  @@index([canonicalName])
  @@index([brand])
}

// וריאציות OCR/משתמש לאותו מוצר
model ProductAlias {
  id        String             @id @default(uuid())
  productId String
  product   Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  alias     String
  source    ProductAliasSource
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([productId, alias])
  @@index([alias])
}

// תצפית מחיר בודדת למוצר
model PriceObservation {
  id             String       @id @default(uuid())
  productId      String
  product        Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  receiptItemId  String?
  receiptItem    ReceiptItem? @relation(fields: [receiptItemId], references: [id], onDelete: SetNull)
  storeId        String?
  store          Store?       @relation(fields: [storeId], references: [id], onDelete: SetNull)
  observedAt     DateTime
  quantity       Decimal?     @db.Decimal(12, 3)
  unitPrice      Decimal?     @db.Decimal(12, 2)
  linePrice      Decimal?     @db.Decimal(12, 2)
  promotionLabel String?
  createdAt      DateTime     @default(now())

  @@index([productId, observedAt])
  @@index([storeId, observedAt])
  @@index([receiptItemId])
}

// הגדרות מערכת
model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ReceiptStatus {
  PENDING_UPLOAD
  PROCESSING
  NEEDS_REVIEW
  COMPLETED
  FAILED
}

enum ReceiptItemReviewStatus {
  UNREVIEWED
  CONFIRMED
  EDITED
  REJECTED
}

enum ProductAliasSource {
  OCR
  USER
  IMPORT
}
